---
// 浮窗联系方式配置 - 可在后台配置
const contactConfig = {
  wechat: '',   // 微信号
  line: '',     // Line ID
  enabled: true // true=显示，false=隐藏
};

const wechatId = contactConfig.wechat;
const lineId = contactConfig.line;
---

{contactConfig.enabled && (
  <div class="fixed-contact">
    <button class="contact-toggle" id="contactToggle">
      <span class="icon">💬</span>
      <span class="text">聯繫我們</span>
    </button>
    
    <div class="contact-popup" id="contactPopup">
      <div class="popup-header">
        <span>聯繫方式</span>
        <button class="close-btn" id="closePopup">×</button>
      </div>
      
      <div class="contact-list">
        {wechatId && (
          <div class="contact-item" data-copy={wechatId}>
            <span class="label">WeChat</span>
            <span class="value">{wechatId}</span>
            <span class="copy-hint">點擊複製</span>
          </div>
        )}
        
        {lineId && (
          <div class="contact-item" data-copy={lineId}>
            <span class="label">Line</span>
            <span class="value">{lineId}</span>
            <span class="copy-hint">點擊複製</span>
          </div>
        )}
        
        {!wechatId && !lineId && (
          <p class="no-contact">（聯繫方式待配置）</p>
        )}
      </div>
    </div>
  </div>
)}

<script>
  const toggle = document.getElementById('contactToggle');
  const popup = document.getElementById('contactPopup');
  const closeBtn = document.getElementById('closePopup');
  
  toggle?.addEventListener('click', () => {
    popup?.classList.toggle('show');
  });
  
  closeBtn?.addEventListener('click', () => {
    popup?.classList.remove('show');
  });
  
  document.addEventListener('click', (e) => {
    const target = e.target as Node;
    if (popup?.classList.contains('show') && !popup.contains(target) && !toggle?.contains(target)) {
      popup.classList.remove('show');
    }
  });
  
  document.querySelectorAll('.contact-item').forEach(item => {
    item.addEventListener('click', async () => {
      const copyText = item.getAttribute('data-copy');
      if (copyText) {
        try {
          await navigator.clipboard.writeText(copyText);
          
          const hint = item.querySelector('.copy-hint') as HTMLElement;
          if (hint) {
            const originalText = hint.textContent;
            hint.textContent = '✅ 已複製!';
            hint.style.color = '#4CAF50';
            setTimeout(() => {
              hint.textContent = originalText;
              hint.style.color = '';
            }, 2000);
          }
        } catch (err) {
          console.error('複製失敗:', err);
        }
      }
    });
  });
</script>

<style>
  .fixed-contact {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 1000;
  }
  
  .contact-toggle {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: linear-gradient(135deg, #1a5c4c 0%, #2d7a5f 100%);
    color: white;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 500;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
  }
  
  .contact-toggle:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.3);
  }
  
  .contact-toggle .icon {
    font-size: 1.2rem;
  }
  
  .contact-popup {
    position: absolute;
    bottom: 60px;
    right: 0;
    width: 280px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
  }
  
  .contact-popup.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  .popup-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    border-bottom: 1px solid #eee;
    font-weight: 600;
    color: var(--color-primary, #1a5c4c);
  }
  
  .close-btn {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: #999;
    cursor: pointer;
    line-height: 1;
  }
  
  .close-btn:hover {
    color: #333;
  }
  
  .contact-list {
    padding: 15px;
  }
  
  .contact-item {
    display: flex;
    flex-direction: column;
    padding: 12px 15px;
    margin-bottom: 10px;
    background: #f8f8f8;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .contact-item:last-child {
    margin-bottom: 0;
  }
  
  .contact-item:hover {
    background: #f0f0f0;
    transform: translateX(5px);
  }
  
  .contact-item .label {
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 4px;
  }
  
  .contact-item .value {
    font-size: 1rem;
    font-weight: 600;
    color: #333;
  }
  
  .contact-item .copy-hint {
    font-size: 0.75rem;
    color: #999;
    margin-top: 4px;
  }
  
  .no-contact {
    text-align: center;
    color: #999;
    padding: 20px;
  }
  
  @media (max-width: 480px) {
    .fixed-contact {
      bottom: 20px;
      right: 20px;
    }
    
    .contact-toggle {
      padding: 12px 16px;
    }
    
    .contact-toggle .text {
      display: none;
    }
    
    .contact-popup {
      width: 250px;
    }
  }
</style>
