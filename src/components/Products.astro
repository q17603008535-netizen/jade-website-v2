---
// 产品参数配置 - 可在后台配置
const productParams = [
  { key: 'weight', label: '重量' },
  { key: 'mine', label: '礦區' },
  { key: 'skin', label: '皮殼' },
  { key: 'water', label: '種水' },
  { key: 'size', label: '尺寸' }
];

const products = [
	{
		id: 1,
		name: '莫西沙 · 冰種',
		image: '',
		params: { weight: '2.5kg', mine: '莫西沙', skin: '翻砂', water: '冰種', size: '12×8×6cm' }
	},
	{
		id: 2,
		name: '會卡 · 糯種',
		image: '',
		params: { weight: '1.8kg', mine: '會卡', skin: '蠟皮', water: '糯種', size: '10×7×5cm' }
	},
	{
		id: 3,
		name: '木那 · 玻璃種',
		image: '',
		params: { weight: '3.2kg', mine: '木那', skin: '脫沙', water: '玻璃種', size: '15×10×8cm' }
	},
	{
		id: 4,
		name: '後江 · 冰糯種',
		image: '',
		params: { weight: '2.1kg', mine: '後江', skin: '油皮', water: '冰糯種', size: '11×7×5cm' }
	},
	{
		id: 5,
		name: '南奇 · 糯冰種',
		image: '',
		params: { weight: '1.5kg', mine: '南奇', skin: '莽帶', water: '糯冰種', size: '9×6×4cm' }
	},
	{
		id: 6,
		name: '莫灣基 · 冰種',
		image: '',
		params: { weight: '2.8kg', mine: '莫灣基', skin: '黑烏沙', water: '冰種', size: '14×9×7cm' }
	}
];
---

<section id="products" class="products">
	<div class="container">
		<h2 class="section-title">產品展示</h2>
		<p class="section-subtitle">每週更新 10+ 款優質翡翠原石</p>
		
		<div class="products-grid">
			{products.map(product => (
				<div class="product-card">
					<div class="product-image">
						{product.image ? (
							<img src={product.image} alt={product.name} />
						) : (
							<div class="image-placeholder">
								<span>📷</span>
							</div>
						)}
						<button class="btn-inquire" data-product={product.name}>立即咨詢</button>
					</div>
					<div class="product-info">
						<h3 class="product-name">{product.name}</h3>
						<div class="product-params">
							{productParams.map(param => (
								product.params[param.key] && (
									<span class="param-tag">{product.params[param.key]}</span>
								)
							))}
						</div>
					</div>
				</div>
			))}
		</div>
		
		<div class="products-note">
			<p>點擊查看更多精彩原石</p>
		</div>
	</div>
</section>

<script>
  document.querySelectorAll('.btn-inquire').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      if (typeof window.openContactModal === 'function') {
        window.openContactModal();
      } else {
        document.getElementById('contact')?.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });
</script>

<style>
	.products {
		background-color: white;
		padding: 80px 0;
	}
	
	.products-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}
	
	.product-card {
		background: white;
		border: 1px solid #eee;
		border-radius: 12px;
		overflow: hidden;
		transition: all 0.3s ease;
	}
	
	.product-card:hover {
		transform: translateY(-8px);
		box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
		border-color: var(--color-primary);
	}
	
	.product-image {
		position: relative;
		aspect-ratio: 1;
		background: linear-gradient(135deg, #f5f5f5 0%, #e8e4dc 100%);
		overflow: hidden;
	}
	
	.product-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}
	
	.image-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 3rem;
		color: #ccc;
	}
	
	.btn-inquire {
		position: absolute;
		bottom: 15px;
		left: 50%;
		transform: translateX(-50%) translateY(60px);
		padding: 12px 30px;
		background: linear-gradient(135deg, #1a5c4c 0%, #2d7a5f 100%);
		color: white;
		border: none;
		border-radius: 30px;
		font-size: 0.95rem;
		font-weight: 500;
		cursor: pointer;
		opacity: 0;
		transition: all 0.3s ease;
		box-shadow: 0 4px 15px rgba(26, 92, 76, 0.3);
	}
	
	.product-card:hover .btn-inquire {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}
	
	.btn-inquire:hover {
		background: linear-gradient(135deg, #0f3d32 0%, #1a5c4c 100%);
		transform: translateX(-50%) scale(1.05);
	}
	
	.product-info {
		padding: 20px;
	}
	
	.product-name {
		font-size: 1.2rem;
		font-weight: 600;
		color: var(--color-dark);
		margin-bottom: 12px;
	}
	
	.product-params {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}
	
	.param-tag {
		display: inline-block;
		padding: 6px 12px;
		background: linear-gradient(135deg, #f8f6f1 0%, #f0ede6 100%);
		border-radius: 20px;
		font-size: 0.8rem;
		color: var(--color-gray);
		border: 1px solid #e8e4dc;
	}
	
	.products-note {
		text-align: center;
		margin-top: 40px;
	}
	
	.products-note p {
		color: var(--color-gray);
		font-size: 1rem;
	}
	
	@media (max-width: 992px) {
		.products-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	
	@media (max-width: 576px) {
		.products-grid {
			grid-template-columns: 1fr;
		}
		
		.products {
			padding: 60px 0;
		}
	}
</style>
